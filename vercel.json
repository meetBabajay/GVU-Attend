{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/src/$1" }
  ],
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "frontend/dist" }
    },
    {
      "src": "backend/src/**/*.js",
      "use": "@vercel/node"
    }
  ]
}
