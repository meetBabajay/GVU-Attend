PORT=5000
NODE_ENV=development
JWT_SECRET=computing_attendance_secret_key_2026

# Database configuration
# Set DB_DIALECT to 'postgres' to switch to a PostgreSQL database
DB_DIALECT=sqlite
DB_STORAGE=./database.sqlite

# PostgreSQL specific variables (ignored if dialect is sqlite)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=attendance_db
DB_USER=postgres
DB_PASS=postgres
